<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contador 7 veces</title>
<style>
body { font-family: Arial; text-align: center; background:#111; color:#fff; }
button { font-size:22px; padding:12px 25px; margin:10px; border-radius:12px; border:none; }
.box { margin:20px; padding:20px; background:#222; border-radius:15px; }
</style>
</head>
<body>

<h2>Contador</h2>

<div class="box">
<h3>Miguel: <span id="m">0</span>/7</h3>
<button onclick="sumar('m')">➕</button>
<button onclick="resetear('m')">🔄</button>
</div>

<div class="box">
<h3>Ashly: <span id="a">0</span>/7</h3>
<button onclick="sumar('a')">➕</button>
<button onclick="resetear('a')">🔄</button>
</div>

<script>
function sumar(id){
 let el = document.getElementById(id);
 let val = parseInt(el.innerText);
 if(val < 7){
   val++;
   el.innerText = val;
   localStorage.setItem(id, val);
 }
}

function resetear(id){
 document.getElementById(id).innerText = 0;
 localStorage.setItem(id, 0);
}

// guardar progreso
window.onload = function(){
 document.getElementById('m').innerText = localStorage.getItem('m') || 0;
 document.getElementById('a').innerText = localStorage.getItem('a') || 0;
}
</script>

</body>
</html>
